// FIXED: Improved Timeframe Mapping with validation
getHigherTF() =>
    result = ""
    currentTF = timeframe.period
    
    // Validate current timeframe
    if na(currentTF)
        result := "60"  // Default to 1H if timeframe is invalid
    else if currentTF == "1"
        result := "15"
    else if currentTF == "3"
        result := "30"	
    else if currentTF == "5"
        result := "60"
    else if currentTF == "15"
        result := "240"
    else if currentTF == "30"
        result := "360"
    else if currentTF == "45"
        result := "540"	
    else if currentTF == "60"
        result := "1D"
    else if currentTF == "120"
        result := "1D"
    else if currentTF == "240"
        result := "1W"
    else if currentTF == "1D"
        result := "1M"
    else if currentTF == "1W"
        result := "3M"
    else if currentTF == "1M"
        result := "12M"
    else
        // Handle unknown timeframes
        result := "60"  // Default to 1H
    
    result

// Get separator's higher timeframe
higherTF = getHigherTF()
// ==========================================
// === Section 2: Data Types ===
// ==========================================

type Sweep
    line htf_marker
    bool is_high
    int end_idx

type Midpoint
    line htf_marker
    float price
    int end_idx

type Candle
    float o = 0.0
    float c = 0.0
    float h = 0.0
    float l = 0.0
    int o_time = 0
    int o_idx = 0
    int c_idx = 0
    int h_idx = 0
    int l_idx = 0
    string dow = ""
    box body
    line wick_up
    line wick_down
    label dow_label
    array<Sweep> sweeps
    array<Midpoint> midpoints

type Imbalance
    box b
    int idx

type CandleSettings
    bool show = false
    string htf = ""
    int max_display = 5

type Settings
    int max_sets = 6
    color bull_body
    color bull_border
    color bull_wick
    color bear_body
    color bear_border
    color bear_wick
    int offset = 10
    int buffer = 1
    int htf_buffer = 10
    int width = 2
    bool use_custom_daily = false
    string custom_daily = "Midnight"
    bool daily_name = true
    bool fvg_show = false
    color fvg_color
    bool vi_show = false
    color vi_color
    bool htf_label_show = true
    color htf_label_color
    string htf_label_size = "small"
    bool htf_timer_show = false
    color htf_timer_color
    string htf_timer_size = "normal"
    color dow_color
    string dow_size = "small"
    string label_pos = "Both"
    string label_align = "Align"
    bool show_htf_candles = true
    bool show_intervals = true
    bool show_open_price = true
    color open_price_color
    int open_price_width = 1
    string open_price_style = "dotted"
    bool show_open_label = true
    color open_label_color
    string open_label_size = "small"
    bool show_mid_line = true
    color mid_line_color
    int mid_line_width = 1
    string mid_line_style = "dotted"
    bool show_mid_label = false
    color mid_label_color

type CandleSet
    array<Candle> candles
    array<Imbalance> imbalances
    array<Sweep> active_sweeps
    array<Midpoint> active_midpoints
    CandleSettings settings
    int tfNumber = 1
    label tfNameTop
    label tfNameBottom
    label tfTimerTop
    label tfTimerBottom
    array<line> openPriceLines
    array<label> openPriceLabels

type Helper
    string name = 'Helper'

