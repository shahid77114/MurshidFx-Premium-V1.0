// FIXED: UpdateTime with null checks
method UpdateTime(CandleSet candleSet, int offset) =>
    if ictSettings.htf_timer_show and (barstate.isrealtime or barstate.islast)
        if not na(candleSet) and not na(candleSet.settings) and not na(candleSet.settings.htf)
            string tmr = '(' + helper.RemainingTime(candleSet.settings.htf) + ')'

            if not na(candleSet.tfTimerTop)
                candleSet.tfTimerTop.set_text(tmr)

            if not na(candleSet.tfTimerBottom)
                candleSet.tfTimerBottom.set_text(tmr)
    
    candleSet

// FIXED: Reorder with comprehensive validation
method Reorder(CandleSet candleSet, int offset) =>
    if not na(candleSet) and not na(candleSet.candles)
        size = candleSet.candles.size()

        if size > 0
            for i = size - 1 to 0
                if i >= 0 and i < size  // Extra bounds check
                    Candle candle = candleSet.candles.get(i)
                    if not na(candle)
                        t_buffer = offset + (ictSettings.width + ictSettings.buffer) * (size - i - 1)
                        
                        if not na(candle.body)
                            box.set_left(candle.body, bar_index + t_buffer)
                            box.set_right(candle.body, bar_index + ictSettings.width + t_buffer)
                        
                        if not na(candle.wick_up)
                            line.set_x1(candle.wick_up, bar_index + ictSettings.width / 2 + t_buffer)
                            line.set_x2(candle.wick_up, bar_index + ictSettings.width / 2 + t_buffer)
                        
                        if not na(candle.wick_down)
                            line.set_x1(candle.wick_down, bar_index + ictSettings.width / 2 + t_buffer)
                            line.set_x2(candle.wick_down, bar_index + ictSettings.width / 2 + t_buffer)

                        if ictSettings.daily_name
                            if not na(candle.dow_label)
                                candle.dow_label.set_y(candle.h)
                                candle.dow_label.set_x(bar_index + ictSettings.width / 2 + t_buffer)
                                candle.dow_label.set_text(candle.dow)
                            else if candle.dow != ""
                                candle.dow_label := label.new(bar_index + ictSettings.width / 2 + t_buffer, candle.h, candle.dow, color = color_transparent, textcolor = ictSettings.dow_color, style = label.style_label_down, size = ictSettings.dow_size)

        top = 0.0
        bottom = 0.0

        if ictSettings.label_align == 'Align'
            top := helper.CandlesHigh(candleSet.candles)
            bottom := helper.CandlesLow(candleSet.candles, top)
        
        if ictSettings.label_align == 'Follow Candles'
            top := helper.CandleSetHigh(candleSet.candles, 0)
            bottom := helper.CandleSetLow(candleSet.candles, top)

        left = bar_index + offset + (ictSettings.width + ictSettings.buffer) * math.max(0, size - 1) / 2

        if ictSettings.htf_label_show and not na(candleSet.settings) and not na(candleSet.settings.htf)
            string lblt = helper.HTFName(candleSet.settings.htf)
            string lbll = lblt
            
            if ictSettings.htf_timer_show
                lblt := lblt + '\n'
                lbll := '\n' + lbll
            
            if ictSettings.daily_name
                lblt := lblt + '\n'

            string tmr = '(' + helper.RemainingTime(candleSet.settings.htf) + ')' + (ictSettings.daily_name ? '\n' : '')
            
            if ictSettings.label_pos == 'Both' or ictSettings.label_pos == 'Top'
                if not na(candleSet.tfNameTop)
                    candleSet.tfNameTop.set_xy(left, top)
                else
                    candleSet.tfNameTop := label.new(left, top, lblt, color = color_transparent, textcolor = ictSettings.htf_label_color, style = label.style_label_down, size = ictSettings.htf_label_size)
                
                if ictSettings.htf_timer_show
                    if not na(candleSet.tfTimerTop)
                        candleSet.tfTimerTop.set_xy(left, top)
                    else
                        candleSet.tfTimerTop := label.new(left, top, tmr, color = color_transparent, textcolor = ictSettings.htf_timer_color, style = label.style_label_down, size = ictSettings.htf_timer_size)
            
            if ictSettings.label_pos == 'Both' or ictSettings.label_pos == 'Bottom'
                if not na(candleSet.tfNameBottom)
                    candleSet.tfNameBottom.set_xy(left, bottom)
                else
                    candleSet.tfNameBottom := label.new(left, bottom, lbll, color = color_transparent, textcolor = ictSettings.htf_label_color, style = label.style_label_up, size = ictSettings.htf_label_size)
                
                if ictSettings.htf_timer_show
                    if not na(candleSet.tfTimerBottom)
                        candleSet.tfTimerBottom.set_xy(left, bottom)
                    else
                        candleSet.tfTimerBottom := label.new(left, bottom, tmr, color = color_transparent, textcolor = ictSettings.htf_timer_color, style = label.style_label_up, size = ictSettings.htf_timer_size)
    
    candleSet

// FIXED: FindImbalance with proper cleanup and validation
method FindImbalance(CandleSet candleSet) =>
    if not na(candleSet) and (barstate.isrealtime or barstate.islast)
        // Clean up existing imbalances
        if not na(candleSet.imbalances) and candleSet.imbalances.size() > 0
            for i = candleSet.imbalances.size() - 1 to 0
                if i >= 0 and i < candleSet.imbalances.size()
                    Imbalance del = candleSet.imbalances.get(i)
                    if not na(del) and not na(del.b)
                        box.delete(del.b)
                    candleSet.imbalances.pop()

        // Find new imbalances
        if not na(candleSet.candles) and candleSet.candles.size() > 3 and ictSettings.fvg_show
            candlesSize = candleSet.candles.size()
            for i = 0 to math.min(candlesSize - 3, candlesSize - 1)
                if i + 2 < candlesSize  // Bounds check
                    candle1 = candleSet.candles.get(i)
                    candle2 = candleSet.candles.get(i + 2)
                    candle3 = candleSet.candles.get(i + 1)

                    if not na(candle1) and not na(candle2) and not na(candle3)
                        // Bullish FVG
                        if candle1.l > candle2.h and math.min(candle1.o, candle1.c) > math.max(candle2.o, candle2.c)
                            Imbalance imb = Imbalance.new()
                            if not na(candle2.body) and not na(candle1.body)
                                imb.b := box.new(box.get_left(candle2.body), candle2.h, box.get_right(candle1.body), candle1.l, bgcolor = ictSettings.fvg_color, border_color = color_transparent, xloc = xloc.bar_index)
                                candleSet.imbalances.push(imb)
                        
                        // Bearish FVG
                        if candle1.h < candle2.l and math.max(candle1.o, candle1.c) < math.min(candle2.o, candle2.c)
                            Imbalance imb = Imbalance.new()
                            if not na(candle1.body) and not na(candle2.body)
                                imb.b := box.new(box.get_right(candle1.body), candle1.h, box.get_left(candle2.body), candle2.l, bgcolor = ictSettings.fvg_color, border_color = color_transparent, xloc = xloc.bar_index)
                                candleSet.imbalances.push(imb)
                        
                        // Refresh candle3 body
                        if not na(candle3.body)
                            box temp = box.copy(candle3.body)
                            box.delete(candle3.body)
                            candle3.body := temp

        // Volume Imbalance
        if not na(candleSet.candles) and candleSet.candles.size() > 2 and ictSettings.vi_show
            candlesSize = candleSet.candles.size()
            for i = 0 to math.min(candlesSize - 2, candlesSize - 1)
                if i + 1 < candlesSize  // Bounds check
                    candle1 = candleSet.candles.get(i)
                    candle2 = candleSet.candles.get(i + 1)
                    
                    if not na(candle1) and not na(candle2)
                        // Bullish VI
                        if candle1.l < candle2.h and math.min(candle1.o, candle1.c) > math.max(candle2.o, candle2.c)
                            Imbalance imb = Imbalance.new()
                            if not na(candle2.body) and not na(candle1.body)
                                imb.b := box.new(box.get_left(candle2.body), math.min(candle1.o, candle1.c), box.get_right(candle1.body), math.max(candle2.o, candle2.c), bgcolor = ictSettings.vi_color, border_color = color_transparent, xloc = xloc.bar_index)
                                candleSet.imbalances.push(imb)
                        
                        // Bearish VI
                        if candle1.h > candle2.l and math.max(candle1.o, candle1.c) < math.min(candle2.o, candle2.c)
                            Imbalance imb = Imbalance.new()
                            if not na(candle1.body) and not na(candle2.body)
                                imb.b := box.new(box.get_right(candle1.body), math.min(candle2.o, candle2.c), box.get_left(candle2.body), math.max(candle1.o, candle1.c), bgcolor = ictSettings.vi_color, border_color = color_transparent, xloc = xloc.bar_index)
                                candleSet.imbalances.push(imb)
    
    candleSet
// FIXED: Monitor method with proper initialization and validation
method Monitor(CandleSet candleSet) =>
    if not na(candleSet) and not na(candleSet.settings) and not na(candleSet.settings.htf)
        // Cache timezone for performance
        timezone = 'America/New_York'
        
        // Determine if new HTF candle based on settings
        isNewHTFCandle = false
        if ictSettings.use_custom_daily and candleSet.settings.htf == '1D'
            isNewHTFCandle := switch ictSettings.custom_daily
                'Midnight' => dayofweek(time, timezone) != dayofweek(time[1], timezone)
                '8:30' => not na(time(timeframe.period, "0830-0831:123456", timezone)) and na(time(timeframe.period, "0830-0831:123456", timezone)[1])
                '9:30' => not na(time(timeframe.period, "0930-0931:123456", timezone)) and na(time(timeframe.period, "0930-0931:123456", timezone)[1])
                => false
        else
            isNewHTFCandle := ta.change(time(candleSet.settings.htf, timezone)) > 0
        
        if isNewHTFCandle
            // Pre-calculate candle properties
            bull = close > open
            body_top = math.max(open, close)
            body_bottom = math.min(open, close)
            
            // Create new candle with optimized initialization
            candle = Candle.new()
            candle.o := open
            candle.c := close
            candle.h := high
            candle.l := low
            candle.o_time := time
            candle.o_idx := bar_index
            candle.c_idx := bar_index
            candle.h_idx := bar_index
            candle.l_idx := bar_index
            
            // Set day of week label with validation
            if candleSet.settings.htf == '1D'
                dow = dayofweek(time_tradingday, timezone)
                candle.dow := helper.DayofWeek(dow)
            else if not na(str.tonumber(candleSet.settings.htf))
                tfNum = str.tonumber(candleSet.settings.htf)
                if tfNum < 60
                    candle.dow := str.format("{0,number,00}", minute(candle.o_time, timezone))
                else if tfNum >= 60
                    candle.dow := str.format("{0,number,00}", hour(candle.o_time, timezone))
            else if candleSet.settings.htf == '1M'
                candle.dow := str.format("{0,number,00}", month(candle.o_time, timezone))
            else
                candle.dow := ''
            
            // Create visual elements
            candle.body := box.new(bar_index, body_top, bar_index + 2, body_bottom, bull ? ictSettings.bull_border : ictSettings.bear_border, 1, bgcolor=bull ? ictSettings.bull_body : ictSettings.bear_body, xloc=xloc.bar_index)
            candle.wick_up := line.new(bar_index + 1, high, bar_index, body_top, color=bull ? ictSettings.bull_wick : ictSettings.bear_wick, xloc=xloc.bar_index)
            candle.wick_down := line.new(bar_index + 1, body_bottom, bar_index, low, color=bull ? ictSettings.bull_wick : ictSettings.bear_wick, xloc=xloc.bar_index)
            
            // Initialize arrays
            candle.sweeps := array.new<Sweep>(0)
            candle.midpoints := array.new<Midpoint>(0)
            
            // Add candle to front of array with validation
            if not na(candleSet.candles)
                candleSet.candles.unshift(candle)
                
                // Remove excess candles and clean up resources
                if candleSet.candles.size() > candleSet.settings.max_display
                    delCandle = candleSet.candles.pop()
                    
                    if not na(delCandle)
                        // Batch delete UI elements
                        if not na(delCandle.body)
                            box.delete(delCandle.body)
                        if not na(delCandle.wick_up)
                            line.delete(delCandle.wick_up)
                        if not na(delCandle.wick_down)
                            line.delete(delCandle.wick_down)
                        
                        if not na(delCandle.dow_label)
                            label.delete(delCandle.dow_label)
                        
                        // Clean up sweeps
                        if not na(delCandle.sweeps) and delCandle.sweeps.size() > 0
                            for i = 0 to delCandle.sweeps.size() - 1
                                if i < delCandle.sweeps.size()
                                    sweep = delCandle.sweeps.get(i)
                                    if not na(sweep) and not na(sweep.htf_marker)
                                        line.delete(sweep.htf_marker)
                            delCandle.sweeps.clear()
                        
                        // Clean up midpoints
                        if not na(delCandle.midpoints) and delCandle.midpoints.size() > 0
                            for i = 0 to delCandle.midpoints.size() - 1
                                if i < delCandle.midpoints.size()
                                    midpoint = delCandle.midpoints.get(i)
                                    if not na(midpoint) and not na(midpoint.htf_marker)
                                        line.delete(midpoint.htf_marker)
                            delCandle.midpoints.clear()
    
    candleSet

// FIXED: CheckSweeps with comprehensive validation
method CheckSweeps(CandleSet candleSet) =>
    // Early exit if sweeps disabled or insufficient candles
    if not showSweeps or na(candleSet) or na(candleSet.candles) or candleSet.candles.size() < 2
        candleSet
    else
        // Validate candles exist
        if candleSet.candles.size() >= 1
            curr_candle = candleSet.candles.get(0)
            
            if not na(curr_candle) and candleSet.candles.size() >= 2
                prev_candle = candleSet.candles.get(1)
                
                if not na(prev_candle)
                    // Initialize sweeps array only when needed
                    if na(curr_candle.sweeps)
                        curr_candle.sweeps := array.new<Sweep>(0)
                    
                    // Cache HTF change check
                    isNewHTFCandle = false
                    if not na(candleSet.settings) and not na(candleSet.settings.htf)
                        isNewHTFCandle := ta.change(time(candleSet.settings.htf)) > 0
                    
                    if isNewHTFCandle and candleSet.candles.size() >= 3
                        candle_before_prev = candleSet.candles.get(2)
                        
                        if not na(candle_before_prev)
                            // Clean up invalidated sweeps from previous candle
                            if not na(prev_candle.sweeps) and prev_candle.sweeps.size() > 0
                                for i = prev_candle.sweeps.size() - 1 to 0
                                    if i >= 0 and i < prev_candle.sweeps.size()
                                        sweep = prev_candle.sweeps.get(i)
                                        if not na(sweep)
                                            should_remove = false
                                            
                                            if sweep.is_high and prev_candle.c >= candle_before_prev.h
                                                should_remove := true
                                            else if not sweep.is_high and prev_candle.c <= candle_before_prev.l
                                                should_remove := true
                                            
                                            if should_remove
                                                if not na(sweep.htf_marker)
                                                    line.delete(sweep.htf_marker)
                                                prev_candle.sweeps.remove(i)
                    
                    // Pre-calculate values for sweep detection
                    next_period_end = curr_candle.o_time + timeframe.in_seconds(candleSet.settings.htf) * 1000
                    t_buffer = ictSettings.offset + (ictSettings.width + ictSettings.buffer) * math.max(0, candleSet.candles.size() - 1)
                    
                    // Check for bearish sweep
                    if high > prev_candle.h and close < prev_candle.h
                        // Look for existing bearish sweep in current HTF candle
                        Sweep existing_bearish_sweep = na
                        if not na(curr_candle.sweeps) and curr_candle.sweeps.size() > 0
                            for i = 0 to curr_candle.sweeps.size() - 1
                                if i < curr_candle.sweeps.size()
                                    sweep_check = curr_candle.sweeps.get(i)
                                    if not na(sweep_check) and sweep_check.is_high
                                        existing_bearish_sweep := sweep_check
                                        break
                        
                        if na(existing_bearish_sweep)
                            // Create new bearish sweep
                            sweep = Sweep.new()
                            sweep.htf_marker := line.new(bar_index - ictSettings.width + t_buffer, prev_candle.h, bar_index + ictSettings.width + t_buffer, prev_candle.h, color=sweepColor, style=line.style_solid, width=sweepWidth)
                            sweep.is_high := true
                            sweep.end_idx := next_period_end
                            curr_candle.sweeps.push(sweep)
                            if not na(candleSet.active_sweeps)
                                candleSet.active_sweeps.push(sweep)
                        else
                            // Update existing bearish sweep line position
                            if not na(existing_bearish_sweep.htf_marker)
                                line.set_xy1(existing_bearish_sweep.htf_marker, bar_index - ictSettings.width + t_buffer, prev_candle.h)
                                line.set_xy2(existing_bearish_sweep.htf_marker, bar_index + ictSettings.width + t_buffer, prev_candle.h)
                            // Update end time
                            existing_bearish_sweep.end_idx := next_period_end
                    
                    // Check for bullish sweep
                    if low < prev_candle.l and close > prev_candle.l
                        // Look for existing bullish sweep in current HTF candle
                        Sweep existing_bullish_sweep = na
                        if not na(curr_candle.sweeps) and curr_candle.sweeps.size() > 0
                            for i = 0 to curr_candle.sweeps.size() - 1
                                if i < curr_candle.sweeps.size()
                                    sweep_check = curr_candle.sweeps.get(i)
                                    if not na(sweep_check) and not sweep_check.is_high
                                        existing_bullish_sweep := sweep_check
                                        break
                        
                        if na(existing_bullish_sweep)
                            // Create new bullish sweep
                            sweep = Sweep.new()
                            sweep.htf_marker := line.new(bar_index - ictSettings.width + t_buffer, prev_candle.l, bar_index + ictSettings.width + t_buffer, prev_candle.l, color=sweepColor, style=line.style_solid, width=sweepWidth)
                            sweep.is_high := false
                            sweep.end_idx := next_period_end
                            curr_candle.sweeps.push(sweep)
                            if not na(candleSet.active_sweeps)
                                candleSet.active_sweeps.push(sweep)
                        else
                            // Update existing bullish sweep line position
                            if not na(existing_bullish_sweep.htf_marker)
                                line.set_xy1(existing_bullish_sweep.htf_marker, bar_index - ictSettings.width + t_buffer, prev_candle.l)
                                line.set_xy2(existing_bullish_sweep.htf_marker, bar_index + ictSettings.width + t_buffer, prev_candle.l)
                            // Update end time
                            existing_bullish_sweep.end_idx := next_period_end
        
        candleSet
// FIXED: CheckMidpoints with comprehensive validation
method CheckMidpoints(CandleSet candleSet) =>
    // Early exit if conditions not met
    if not showMidpoints or na(candleSet) or na(candleSet.candles) or candleSet.candles.size() < 2
        candleSet
    else
        // Validate candles exist
        if candleSet.candles.size() >= 1
            curr_candle = candleSet.candles.get(0)
            
            if not na(curr_candle)
                // Initialize midpoints array if needed
                if na(curr_candle.midpoints)
                    curr_candle.midpoints := array.new<Midpoint>()
                    
                // Cache frequently used values
                isNewHTFCandle = false
                if not na(candleSet.settings) and not na(candleSet.settings.htf)
                    htf_change = ta.change(time(candleSet.settings.htf))
                    isNewHTFCandle := htf_change > 0
                
                if isNewHTFCandle
                    // Clear existing midpoints with validation
                    if not na(candleSet.active_midpoints) and candleSet.active_midpoints.size() > 0
                        for i = candleSet.active_midpoints.size() - 1 to 0
                            if i >= 0 and i < candleSet.active_midpoints.size()
                                midpoint = candleSet.active_midpoints.get(i)
                                if not na(midpoint) and not na(midpoint.htf_marker)
                                    line.delete(midpoint.htf_marker)
                                candleSet.active_midpoints.remove(i)
                    
                    if not na(curr_candle.midpoints) and curr_candle.midpoints.size() > 0
                        for i = curr_candle.midpoints.size() - 1 to 0
                            if i >= 0 and i < curr_candle.midpoints.size()
                                midpoint = curr_candle.midpoints.get(i)
                                if not na(midpoint) and not na(midpoint.htf_marker)
                                    line.delete(midpoint.htf_marker)
                                curr_candle.midpoints.remove(i)
                    
                    // Calculate and create new midpoint
                    if candleSet.candles.size() >= 2
                        prev_candle = candleSet.candles.get(1)
                        if not na(prev_candle)
                            midpoint_price = (prev_candle.h + prev_candle.l) / 2
                            next_period_end = curr_candle.o_time + timeframe.in_seconds(candleSet.settings.htf) * 1000
                            
                            // Create midpoint object
                            midpoint = Midpoint.new()
                            midpoint.price := midpoint_price
                            midpoint.end_idx := next_period_end
                            
                            // Create HTF marker
                            t_buffer = ictSettings.offset + (ictSettings.width + ictSettings.buffer) * math.max(0, candleSet.candles.size() - 1)
                            midpoint.htf_marker := line.new(bar_index - ictSettings.width + t_buffer, midpoint_price, bar_index + ictSettings.width + t_buffer, midpoint_price, color=midpointColor, style=line.style_dotted, width=midpointWidth)
                            
                            // Add to arrays
                            curr_candle.midpoints.push(midpoint)
                            if not na(candleSet.active_midpoints)
                                candleSet.active_midpoints.push(midpoint)
        
        candleSet

// FIXED: DrawOpenPriceLines with proper cleanup
method DrawOpenPriceLines(CandleSet candleSet) =>
    if not na(candleSet)
        // HTF candles open price lines disabled - only interval open price lines are shown
        // Clear any existing HTF open price lines and labels
        if not na(candleSet.openPriceLines)
            openLinesSize = array.size(candleSet.openPriceLines)
            if openLinesSize > 0
                for i = 0 to openLinesSize - 1
                    if i < openLinesSize
                        lineObj = array.get(candleSet.openPriceLines, i)
                        if not na(lineObj)
                            line.delete(lineObj)
                array.clear(candleSet.openPriceLines)
        
        if not na(candleSet.openPriceLabels)
            openLabelsSize = array.size(candleSet.openPriceLabels)
            if openLabelsSize > 0
                for i = 0 to openLabelsSize - 1
                    if i < openLabelsSize
                        labelObj = array.get(candleSet.openPriceLabels, i)
                        if not na(labelObj)
                            label.delete(labelObj)
                array.clear(candleSet.openPriceLabels)
    
    candleSet

// FIXED: Update method with validation
method Update(CandleSet candleSet, int offset) =>
    if not na(candleSet) and not na(candleSet.candles) and candleSet.candles.size() > 0
        Candle candle = candleSet.candles.first()
        if not na(candle)
            candle.h_idx := high > candle.h ? bar_index : candle.h_idx
            candle.h := high > candle.h ? high : candle.h
            candle.l_idx := low < candle.l ? bar_index : candle.l_idx
            candle.l := low < candle.l ? low : candle.l
            candle.c := close
            candle.c_idx := bar_index

            bull = candle.c > candle.o

            if not na(candle.body)
                box.set_top(candle.body, math.max(candle.o, candle.c))
                box.set_bottom(candle.body, math.min(candle.o, candle.c))
                box.set_bgcolor(candle.body, bull ? ictSettings.bull_body : ictSettings.bear_body)
                box.set_border_color(candle.body, bull ? ictSettings.bull_border : ictSettings.bear_border)
            
            if not na(candle.wick_up)
                line.set_color(candle.wick_up, bull ? ictSettings.bull_wick : ictSettings.bear_wick)
                line.set_y1(candle.wick_up, candle.h)
                line.set_y2(candle.wick_up, math.max(candle.o, candle.c))
            
            if not na(candle.wick_down)
                line.set_color(candle.wick_down, bull ? ictSettings.bull_wick : ictSettings.bear_wick)
                line.set_y1(candle.wick_down, candle.l)
                line.set_y2(candle.wick_down, math.min(candle.o, candle.c))

            if barstate.isrealtime or barstate.islast
                candleSet.Reorder(offset)
                candleSet.DrawOpenPriceLines()
    
    candleSet

// ==========================================
// === Section 5: Symbol Info Table ===
// ==========================================

var table symbolInfoTable = table.new(position.bottom_right, 1, 2, bgcolor=color.new(#ffffff, 20), border_width=1, border_color=color.gray)
if barstate.islast
    // Format the date and time with current time for real-time updates
    dateText = formatDate(timenow)
    timeText = formatTime(timenow)
    
    symbolInfoText = syminfo.ticker + " | " + timeframe.period + (timeframe.isminutes ? "M" : "")
    dateTimeText = dateText + " " + timeText
    
    table.cell(symbolInfoTable, 0, 0, symbolInfoText, text_color=color.rgb(0, 0, 0), text_size=size.normal, text_halign=text.align_center)
    table.cell(symbolInfoTable, 0, 1, dateTimeText, text_color=color.rgb(0, 0, 0), text_size=size.normal, text_halign=text.align_center)

// ==========================================
// === Section 6: Interval Separator and HTF Candles Execution ===
// ==========================================

// FIXED: Update HTF settings based on current timeframe (only once)
if barstate.isfirst
    if higherTF == "15" or higherTF == "30"
        htf1.settings.show := true
        htf1.settings.htf := higherTF
        htf1.settings.max_display := displayCount
    else if higherTF == "60" or higherTF == "120" or higherTF == "240" or higherTF == "360" or higherTF == "540" or higherTF == "720"
        htf2.settings.show := true
        htf2.settings.htf := higherTF
        htf2.settings.max_display := displayCount
    else if higherTF == "1D"
        htf3.settings.show := true
        htf3.settings.htf := higherTF
        htf3.settings.max_display := displayCount
    else if higherTF == "1W"
        htf4.settings.show := true
        htf4.settings.htf := higherTF
        htf4.settings.max_display := displayCount
    else if higherTF == "1M" or higherTF == "3M"
        htf5.settings.show := true
        htf5.settings.htf := higherTF
        htf5.settings.max_display := displayCount
    else if higherTF == "12M"
        htf6.settings.show := true
        htf6.settings.htf := higherTF
        htf6.settings.max_display := displayCount

// Draw interval separators
if ictSettings.show_intervals
    // Get higher timeframe data
    higherTFTime = request.security(syminfo.tickerid, higherTF, time, lookahead=barmerge.lookahead_on)
    higherTFClose = request.security(syminfo.tickerid, higherTF, time_close, lookahead=barmerge.lookahead_on)
    higherTFHigh = request.security(syminfo.tickerid, higherTF, high, lookahead=barmerge.lookahead_on)
    higherTFLow = request.security(syminfo.tickerid, higherTF, low, lookahead=barmerge.lookahead_on)
    higherTFOpen = request.security(syminfo.tickerid, higherTF, open, lookahead=barmerge.lookahead_on)

    // Track period changes
    var int currentHTFTime = na
    var bool newHTFPeriod = false
    var int[] historicalTimes = array.new_int()
    var int[] historicalCloses = array.new_int()
    var float[] historicalHighs = array.new_float()
    var float[] historicalLows = array.new_float()
    var float[] historicalOpens = array.new_float()
    var line[] allLines = array.new_line()
    var line[] openPriceLines = array.new_line()
    var label[] openPriceLabels = array.new_label()
    var line[] midLines = array.new_line()
    var label[] midLabels = array.new_label()

    if not na(higherTFTime) and not na(higherTFClose)
        newHTFPeriod := higherTFTime != currentHTFTime
        currentHTFTime := higherTFTime
        
        if newHTFPeriod
            // Store new period data
            array.unshift(historicalTimes, currentHTFTime)
            array.unshift(historicalCloses, higherTFClose)
            array.unshift(historicalHighs, higherTFHigh)
            array.unshift(historicalLows, higherTFLow)
            array.unshift(historicalOpens, higherTFOpen)
            
            // Maintain history length with bounds checking
            historicalTimesSize = array.size(historicalTimes)
            if historicalTimesSize > displayCount
                // Use consistent array operations (FIFO)
                if historicalTimesSize > 0
                    array.pop(historicalTimes)
                    array.pop(historicalCloses)
                    array.pop(historicalHighs)
                    array.pop(historicalLows)
                    array.pop(historicalOpens)
            
            // Safely clear previous lines with error handling
            allLinesSize = array.size(allLines)
            if allLinesSize > 0
                for i = 0 to allLinesSize - 1
                    if i < array.size(allLines)
                        lineObj = array.get(allLines, i)
                        if not na(lineObj)
                            line.delete(lineObj)
                array.clear(allLines)
            
            // Clear previous open price lines and labels
            if ictSettings.show_open_price
                openLinesSize = array.size(openPriceLines)
                if openLinesSize > 0
                    for i = 0 to openLinesSize - 1
                        if i < array.size(openPriceLines)
                            lineObj = array.get(openPriceLines, i)
                            if not na(lineObj)
                                line.delete(lineObj)
                    array.clear(openPriceLines)
                
                openLabelsSize = array.size(openPriceLabels)
                if openLabelsSize > 0
                    for i = 0 to openLabelsSize - 1
                        if i < array.size(openPriceLabels)
                            labelObj = array.get(openPriceLabels, i)
                            if not na(labelObj)
                                label.delete(labelObj)
                    array.clear(openPriceLabels)
            
            // Clear previous mid-lines and labels
            if ictSettings.show_mid_line
                midLinesSize = array.size(midLines)
                if midLinesSize > 0
                    for i = 0 to midLinesSize - 1
                        if i < array.size(midLines)
                            lineObj = array.get(midLines, i)
                            if not na(lineObj)
                                line.delete(lineObj)
                    array.clear(midLines)
                
                midLabelsSize = array.size(midLabels)
                if midLabelsSize > 0
                    for i = 0 to midLabelsSize - 1
                        if i < array.size(midLabels)
                            labelObj = array.get(midLabels, i)
                            if not na(labelObj)
                                label.delete(labelObj)
                    array.clear(midLabels)
            
            // Draw new boxes with unified style
            if historicalTimesSize > 0
                for i = 0 to math.min(historicalTimesSize - 1, displayCount - 1)
                    if i < array.size(historicalTimes)
                        startTime = array.get(historicalTimes, i)
                        endTime = array.get(historicalCloses, i)
                        periodHigh = array.get(historicalHighs, i)
                        periodLow = array.get(historicalLows, i)
                        
                        if not na(startTime) and not na(endTime)
                            // Create all four borders with same style
                            leftLine = line.new(startTime, high, startTime, low, xloc=xloc.bar_time, extend=extend.both, color=boxColor, width=lineWidth, style=getLineStyle())
                            rightLine = line.new(endTime, high, endTime, low, xloc=xloc.bar_time, extend=extend.both, color=boxColor, width=lineWidth, style=getLineStyle())
                            topLine = line.new(startTime, periodHigh, endTime, periodHigh, xloc=xloc.bar_time, extend=extend.none, color=boxColor, width=lineWidth, style=getLineStyle())
                            bottomLine = line.new(startTime, periodLow, endTime, periodLow, xloc=xloc.bar_time, extend=extend.none, color=boxColor, width=lineWidth, style=getLineStyle())
                            
                            // Store all lines
                            array.push(allLines, leftLine)
                            array.push(allLines, rightLine)
                            array.push(allLines, topLine)
                            array.push(allLines, bottomLine)
                            
                            // Draw open price line only for current interval (i == 0)
                            if ictSettings.show_open_price and i == 0
                                periodOpen = array.get(historicalOpens, i)
                                if not na(periodOpen)
                                    // Create open price line from start to end of current interval
                                    openLine = line.new(startTime, periodOpen, endTime, periodOpen, xloc=xloc.bar_time, extend=extend.none, color=ictSettings.open_price_color, width=ictSettings.open_price_width, style=getOpenPriceLineStyle())
                                    array.push(openPriceLines, openLine)
                                    
                                    // Create open label if enabled (positioned exactly at interval end line)
                                    if ictSettings.show_open_label
                                        // Position label exactly at the interval end line with no spacing
                                        labelTime = math.round(endTime)  // Exactly at the end line
                                        labelSize = ictSettings.open_label_size == "tiny" ? size.tiny : ictSettings.open_label_size == "small" ? size.small : ictSettings.open_label_size == "normal" ? size.normal : size.large
                                        openLabel = label.new(labelTime, periodOpen, "Open", color=color_transparent, textcolor=ictSettings.open_label_color, style=label.style_label_left, size=labelSize, xloc=xloc.bar_time)
                                        array.push(openPriceLabels, openLabel)
                                    
                            // Draw mid-line for the most recent closed interval (i == 1), extended to current interval end
                            if ictSettings.show_mid_line and i == 1 and array.size(historicalHighs) > 1
                                midPeriodHigh = array.get(historicalHighs, i)
                                midPeriodLow = array.get(historicalLows, i)
                                if not na(midPeriodHigh) and not na(midPeriodLow)
                                    // Calculate mid-point of high-low range
                                    midPrice = (midPeriodHigh + midPeriodLow) / 2
                                    
                                    // Determine current interval end time (index 0's close time) to extend the line to
                                    currentIntervalEnd = array.size(historicalCloses) > 0 ? array.get(historicalCloses, 0) : endTime
                                    
                                    // Create mid-line extended to the current interval end point
                                    midLine = line.new(startTime, midPrice, currentIntervalEnd, midPrice, xloc=xloc.bar_time, extend=extend.none, color=ictSettings.mid_line_color, width=ictSettings.mid_line_width, style=getMidLineStyle())
                                    array.push(midLines, midLine)
                                    
                                    // Create mid label if enabled at the current interval end point
                                    if ictSettings.show_mid_label
                                        midLabelSize = ictSettings.open_label_size == "tiny" ? size.tiny : ictSettings.open_label_size == "small" ? size.small : ictSettings.open_label_size == "normal" ? size.normal : size.large
                                        midLabel = label.new(currentIntervalEnd, midPrice, "Mid", color=color_transparent, textcolor=ictSettings.mid_label_color, style=label.style_label_left, size=midLabelSize, xloc=xloc.bar_time)
                                        array.push(midLabels, midLabel)

// ==========================================
// === Section 6.5: Independent Open Price Lines ===
// ==========================================

// Draw open price lines independently of interval separators
if ictSettings.show_open_price and not ictSettings.show_intervals
    // Get higher timeframe data for open price lines only
    higherTFTime = request.security(syminfo.tickerid, higherTF, time, lookahead=barmerge.lookahead_on)
    higherTFClose = request.security(syminfo.tickerid, higherTF, time_close, lookahead=barmerge.lookahead_on)
    higherTFOpen = request.security(syminfo.tickerid, higherTF, open, lookahead=barmerge.lookahead_on)
    
    // Track period changes for open price lines
    var int currentHTFTimeOpen = na
    var bool newHTFPeriodOpen = false
    var int[] historicalTimesOpen = array.new_int()
    var int[] historicalClosesOpen = array.new_int()
    var float[] historicalOpensOpen = array.new_float()
    var line[] openPriceLinesOnly = array.new_line()
    var label[] openPriceLabelsOnly = array.new_label()
    
    if not na(higherTFTime) and not na(higherTFClose)
        newHTFPeriodOpen := higherTFTime != currentHTFTimeOpen
        currentHTFTimeOpen := higherTFTime
        
        if newHTFPeriodOpen
            // Store new period data
            array.unshift(historicalTimesOpen, currentHTFTimeOpen)
            array.unshift(historicalClosesOpen, higherTFClose)
            array.unshift(historicalOpensOpen, higherTFOpen)
            
            // Maintain history length
            historicalTimesOpenSize = array.size(historicalTimesOpen)
            if historicalTimesOpenSize > displayCount
                if historicalTimesOpenSize > 0
                    array.pop(historicalTimesOpen)
                    array.pop(historicalClosesOpen)
                    array.pop(historicalOpensOpen)
            
            // Clear previous open price lines and labels
            openLinesOnlySize = array.size(openPriceLinesOnly)
            if openLinesOnlySize > 0
                for i = 0 to openLinesOnlySize - 1
                    if i < array.size(openPriceLinesOnly)
                        lineObj = array.get(openPriceLinesOnly, i)
                        if not na(lineObj)
                            line.delete(lineObj)
                array.clear(openPriceLinesOnly)
            
            openLabelsOnlySize = array.size(openPriceLabelsOnly)
            if openLabelsOnlySize > 0
                for i = 0 to openLabelsOnlySize - 1
                    if i < array.size(openPriceLabelsOnly)
                        labelObj = array.get(openPriceLabelsOnly, i)
                        if not na(labelObj)
                            label.delete(labelObj)
                array.clear(openPriceLabelsOnly)
            
            // Draw open price lines only for current interval
            if historicalTimesOpenSize > 0
                for i = 0 to math.min(historicalTimesOpenSize - 1, displayCount - 1)
                    if i < array.size(historicalTimesOpen) and i == 0
                        startTime = array.get(historicalTimesOpen, i)
                        endTime = array.get(historicalClosesOpen, i)
                        periodOpen = array.get(historicalOpensOpen, i)
                        
                        if not na(startTime) and not na(endTime) and not na(periodOpen)
                            // Create open price line from start to end of current interval
                            openLine = line.new(startTime, periodOpen, endTime, periodOpen, xloc=xloc.bar_time, extend=extend.none, color=ictSettings.open_price_color, width=ictSettings.open_price_width, style=getOpenPriceLineStyle())
                            array.push(openPriceLinesOnly, openLine)
                            
                            // Create open label if enabled
                            if ictSettings.show_open_label
                                labelTime = math.round(endTime)
                                labelSize = ictSettings.open_label_size == "tiny" ? size.tiny : ictSettings.open_label_size == "small" ? size.small : ictSettings.open_label_size == "normal" ? size.normal : size.large
                                openLabel = label.new(labelTime, periodOpen, "Open", color=color_transparent, textcolor=ictSettings.open_label_color, style=label.style_label_left, size=labelSize, xloc=xloc.bar_time)
                                array.push(openPriceLabelsOnly, openLabel)

// ==========================================
// === Section 7: HTF Candles Execution ===
// ==========================================

// Process HTF Candles - Monitor calls on each calculation (unconditional)
htf1.Monitor()
htf2.Monitor()
htf3.Monitor()
htf4.Monitor()
htf5.Monitor()
htf6.Monitor()

// Process HTF Candles
processHTFCandles() =>
    int offset = ictSettings.offset
    int cnt = 0
    
    if ictSettings.show_htf_candles
        if htf1.settings.show and helper.ValidTimeframe(htf1.settings.htf)
            htf1.UpdateTime(offset)
            htf1.Update(offset).FindImbalance().CheckSweeps().CheckMidpoints()
            cnt := cnt + 1
            offset := calculateHTFOffset(htf1.candles, offset)
        
        if htf2.settings.show and helper.ValidTimeframe(htf2.settings.htf) and cnt < helper.HTFEnabled()
            htf2.UpdateTime(offset)
            htf2.Update(offset).FindImbalance().CheckSweeps().CheckMidpoints()
            cnt := cnt + 1
            offset := calculateHTFOffset(htf2.candles, offset)
        
        if htf3.settings.show and helper.ValidTimeframe(htf3.settings.htf) and cnt < helper.HTFEnabled()
            htf3.UpdateTime(offset)
            htf3.Update(offset).FindImbalance().CheckSweeps().CheckMidpoints()
            cnt := cnt + 1
            offset := calculateHTFOffset(htf3.candles, offset)
        
        if htf4.settings.show and helper.ValidTimeframe(htf4.settings.htf) and cnt < helper.HTFEnabled()
            htf4.UpdateTime(offset)
            htf4.Update(offset).FindImbalance().CheckSweeps().CheckMidpoints()
            cnt := cnt + 1
            offset := calculateHTFOffset(htf4.candles, offset)
        
        if htf5.settings.show and helper.ValidTimeframe(htf5.settings.htf) and cnt < helper.HTFEnabled()
            htf5.UpdateTime(offset)
            htf5.Update(offset).FindImbalance().CheckSweeps().CheckMidpoints()
            cnt := cnt + 1
            offset := calculateHTFOffset(htf5.candles, offset)
        
        if htf6.settings.show and helper.ValidTimeframe(htf6.settings.htf) and cnt < helper.HTFEnabled()
            htf6.UpdateTime(offset)
            htf6.Update(offset).FindImbalance().CheckSweeps().CheckMidpoints()
    
    cnt

// Execute HTF Candle processing
processHTFCandles()

// ==========================================
// === Section 8: Professional Dashboard Display ===
// ==========================================

// Create enhanced professional mini dashboard with visual separations
dashboardPos = dashboardPosition == "top-left" ? position.top_left : dashboardPosition == "top-right" ? position.top_right : dashboardPosition == "bottom-left" ? position.bottom_left : position.bottom_right
var table dashboardTable = table.new(dashboardPos, 1, 5, bgcolor=dashboardBgColor, border_width=2, border_color=dashboardBorderColor, frame_width=1, frame_color=dashboardBorderColor)

// Update dashboard with all information
if showDashboard and barstate.islast
    // Calculate remaining time for HTF candle (using original format)
    remainingTime = calculateRemainingTimeOriginal()
    
    // Format dashboard content with enhanced separations
    headerText = "🏷️ " + dashboardTitle
    mottoText = "💎 " + dashboardMotto
    symbolText = "📈 Symbol: " + syminfo.ticker + " | Chart: " + timeframe.period + (timeframe.isminutes ? "M" : "")
    htfText = "🕯️ HTF: " + getHTFName(higherTF) + " | Remaining: " + remainingTime
    dateTimeText = "📅 Date: " + formatDashboardDate(timenow) + " | Time: " + formatDashboardTime(timenow)
    
    // Update dashboard cells with enhanced professional styling
    table.cell(dashboardTable, 0, 0, headerText, text_color=textColor, text_size=size.normal, text_halign=text.align_center, bgcolor=headerBgColor)
    table.cell(dashboardTable, 0, 1, mottoText, text_color=mottoTextColor, text_size=size.small, text_halign=text.align_center, bgcolor=mottoBgColor)
    table.cell(dashboardTable, 0, 2, symbolText, text_color=textColor, text_size=size.small, text_halign=text.align_left, bgcolor=dashboardBgColor)
    table.cell(dashboardTable, 0, 3, htfText, text_color=textColor, text_size=size.small, text_halign=text.align_left, bgcolor=dashboardBgColor)
    table.cell(dashboardTable, 0, 4, dateTimeText, text_color=textColor, text_size=size.small, text_halign=text.align_left, bgcolor=dashboardBgColor)
