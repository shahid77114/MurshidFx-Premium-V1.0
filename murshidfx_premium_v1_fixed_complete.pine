// Helper function to calculate offset for HTF sets
calculateHTFOffset(array<Candle> candles, int currentOffset) =>
    candlesSize = array.size(candles)
    if candlesSize > 0
        currentOffset + (candlesSize * ictSettings.width + (candlesSize - 1) * ictSettings.buffer + ictSettings.htf_buffer)
    else
        currentOffset + ictSettings.htf_buffer

// Convert style to line.style constant
getLineStyle() => 
    if lineStyle == "solid"
        line.style_solid
    else if lineStyle == "dotted"
        line.style_dotted
    else
        line.style_dashed

// Convert open price style to line.style constant
getOpenPriceLineStyle() => 
    if openPriceStyle == "solid"
        line.style_solid
    else if openPriceStyle == "dotted"
        line.style_dotted
    else
        line.style_dashed

// Convert mid-line style to line.style constant
getMidLineStyle() => 
    if midLineStyle == "solid"
        line.style_solid
    else if midLineStyle == "dotted"
        line.style_dotted
    else
        line.style_dashed

// FIXED: Format date with proper bounds checking
formatDate(timestamp) =>
    months = array.from("Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec")
    // Use New York timezone for consistent display
    day = dayofmonth(timestamp, "America/New_York")
    monthVal = month(timestamp, "America/New_York")
    yearVal = year(timestamp, "America/New_York")
    
    // FIXED: Add proper bounds checking for month array access
    monthStr = "Invalid"
    if monthVal >= 1 and monthVal <= 12 and array.size(months) >= 12
        monthStr := array.get(months, monthVal - 1)
    
    dayStr = day < 10 ? "0" + str.tostring(day) : str.tostring(day)
    
    dayStr + "-" + monthStr + "-" + str.tostring(yearVal)

// FIXED: Format time with proper validation
formatTime(timestamp) =>
    // Get current time in New York timezone
    currentTime = timenow
    hourVal = hour(currentTime, "America/New_York")
    minuteVal = minute(currentTime, "America/New_York")
    
    // Validate hour and minute values
    hourVal := math.max(0, math.min(23, hourVal))
    minuteVal := math.max(0, math.min(59, minuteVal))
    
    hourStr = hourVal < 10 ? "0" + str.tostring(hourVal) : str.tostring(hourVal)
    minuteStr = minuteVal < 10 ? "0" + str.tostring(minuteVal) : str.tostring(minuteVal)
    
    hourStr + ":" + minuteStr

Helper helper = Helper.new()
color color_transparent = #ffffff00

method LineStyle(Helper helper, string style) =>
    helper.name := style
    result = line.style_solid
    
    if style == '----'
        result := line.style_dashed
    else if style == '····'
        result := line.style_dotted
    
    result

method DayofWeek(Helper helper, int index) =>
    helper.name := 'DOW'
    result = ''
    
    // FIXED: Validate index bounds
    if index >= 1 and index <= 7
        if index == 1
            result := 'M'
        else if index == 2
            result := 'T'
        else if index == 3
            result := 'W'
        else if index == 4
            result := 'T'
        else if index == 5
            result := 'F'
        else if index == 6
            result := 'S'
        else if index == 7
            result := 'S'
    
    result

// FIXED: ValidTimeframe with proper error handling
method ValidTimeframe(Helper helper, string HTF) =>
    helper.name := HTF
    isValid = false
    
    // FIXED: Add comprehensive error handling
    if not na(HTF) and HTF != ""
        htfSeconds = timeframe.in_seconds(HTF)
        currentSeconds = timeframe.in_seconds()
        
        if not na(htfSeconds) and not na(currentSeconds) and currentSeconds > 0
            if htfSeconds >= timeframe.in_seconds('D') and htfSeconds > currentSeconds
                isValid := true
            else if currentSeconds < htfSeconds
                // FIXED: Safe division check
                ratio = htfSeconds / currentSeconds
                if math.round(ratio) == ratio
                    isValid := true
    
    isValid

// FIXED: RemainingTime with error handling
method RemainingTime(Helper helper, string HTF) =>
    helper.name := HTF
    result = 'n/a'
    
    if barstate.isrealtime and not na(HTF) and HTF != ""
        closeTime = time_close(HTF)
        if not na(closeTime) and closeTime > timenow
            timeRemaining = (closeTime - timenow) / 1000
            
            // Validate timeRemaining is positive
            if timeRemaining > 0
                days = math.floor(timeRemaining / 86400)
                hours = math.floor((timeRemaining - days * 86400) / 3600)
                minutes = math.floor((timeRemaining - days * 86400 - hours * 3600) / 60)
                seconds = math.floor(timeRemaining - days * 86400 - hours * 3600 - minutes * 60)

                // Ensure values are within valid ranges
                days := math.max(0, days)
                hours := math.max(0, math.min(23, hours))
                minutes := math.max(0, math.min(59, minutes))
                seconds := math.max(0, math.min(59, seconds))

                result := str.tostring(seconds, '00')
                
                if minutes > 0 or hours > 0 or days > 0
                    result := str.tostring(minutes, '00') + ':' + result
                
                if hours > 0 or days > 0
                    result := str.tostring(hours, '00') + ':' + result
                
                if days > 0
                    result := str.tostring(days) + 'D ' + result
    
    result

// FIXED: HTFName with validation
method HTFName(Helper helper, string HTF) =>
    helper.name := 'HTFName'
    formatted = HTF

    if not na(HTF) and HTF != ""
        seconds = timeframe.in_seconds(HTF)
        
        if not na(seconds) and seconds > 0
            if seconds < 60
                formatted := str.tostring(seconds) + 's'
            else if seconds / 60 < 60
                formatted := str.tostring(math.round(seconds / 60)) + 'm'
            else if seconds / 60 / 60 < 24
                formatted := str.tostring(math.round(seconds / 60 / 60)) + 'H'
    
    formatted

method HTFEnabled(Helper helper) =>
    helper.name := 'HTFEnabled'
    int enabled = 0
    
    if ictSettings.show_htf_candles
        if htf1.settings.show and helper.ValidTimeframe(htf1.settings.htf)
            enabled := enabled + 1
        
        if htf2.settings.show and helper.ValidTimeframe(htf2.settings.htf)
            enabled := enabled + 1
        
        if htf3.settings.show and helper.ValidTimeframe(htf3.settings.htf)
            enabled := enabled + 1
        
        if htf4.settings.show and helper.ValidTimeframe(htf4.settings.htf)
            enabled := enabled + 1
        
        if htf5.settings.show and helper.ValidTimeframe(htf5.settings.htf)
            enabled := enabled + 1
        
        if htf6.settings.show and helper.ValidTimeframe(htf6.settings.htf)
            enabled := enabled + 1
    
    int last = math.min(enabled, ictSettings.max_sets)
    last

// FIXED: CandleSetHigh with proper validation
method CandleSetHigh(Helper helper, array<Candle> candles, float h) =>
    helper.name := 'CandlesSetHigh'
    float _h = h
    
    if not na(candles)
        candlesSize = array.size(candles)
        if candlesSize > 0
            for i = 0 to candlesSize - 1
                if i < candlesSize  // Extra bounds check
                    Candle c = array.get(candles, i)
                    if not na(c) and not na(c.h) and c.h > _h
                        _h := c.h
    
    _h

// FIXED: CandleSetLow with proper validation
method CandleSetLow(Helper helper, array<Candle> candles, float l) =>
    helper.name := 'CandlesSetLow'
    float _l = l
    
    if not na(candles)
        candlesSize = array.size(candles)
        if candlesSize > 0
            for i = 0 to candlesSize - 1
                if i < candlesSize  // Extra bounds check
                    Candle c = array.get(candles, i)
                    if not na(c) and not na(c.l) and c.l < _l
                        _l := c.l
    
    _l

// FIXED: CandlesHigh with proper validation
method CandlesHigh(Helper helper, array<Candle> candles) =>
    helper.name := 'CandlesHigh'
    h = 0.0
    int cnt = 0
    int last = helper.HTFEnabled()

    if ictSettings.show_htf_candles and last > 0
        if htf1.settings.show and helper.ValidTimeframe(htf1.settings.htf)
            h := helper.CandleSetHigh(htf1.candles, h)
            cnt := cnt + 1
        
        if htf2.settings.show and helper.ValidTimeframe(htf2.settings.htf) and cnt < last
            h := helper.CandleSetHigh(htf2.candles, h)
            cnt := cnt + 1
        
        if htf3.settings.show and helper.ValidTimeframe(htf3.settings.htf) and cnt < last
            h := helper.CandleSetHigh(htf3.candles, h)
            cnt := cnt + 1
        
        if htf4.settings.show and helper.ValidTimeframe(htf4.settings.htf) and cnt < last
            h := helper.CandleSetHigh(htf4.candles, h)
            cnt := cnt + 1
        
        if htf5.settings.show and helper.ValidTimeframe(htf5.settings.htf) and cnt < last
            h := helper.CandleSetHigh(htf5.candles, h)
            cnt := cnt + 1
        
        if htf6.settings.show and helper.ValidTimeframe(htf6.settings.htf) and cnt < last
            h := helper.CandleSetHigh(htf6.candles, h)

    // Additional validation for passed candles array
    if not na(candles)
        candlesSize = array.size(candles)
        if candlesSize > 0
            for i = 0 to candlesSize - 1
                if i < candlesSize
                    Candle c = array.get(candles, i)
                    if not na(c) and not na(c.h) and c.h > h
                        h := c.h
    
    h

// FIXED: CandlesLow with proper validation
method CandlesLow(Helper helper, array<Candle> candles, float h) =>
    helper.name := 'CandlesLow'
    l = h
    int cnt = 0
