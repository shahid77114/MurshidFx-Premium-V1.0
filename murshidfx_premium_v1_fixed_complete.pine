// FIXED: Get HTF name formatted for display with validation
getHTFName(string HTF) =>
    formatted = HTF
    
    if not na(HTF) and HTF != ""
        seconds = timeframe.in_seconds(HTF)
        
        if not na(seconds) and seconds > 0
            if seconds < 60
                formatted := str.tostring(seconds) + 's'
            else if seconds / 60 < 60
                formatted := str.tostring(math.round(seconds / 60)) + 'm'
            else if seconds / 60 / 60 < 24
                formatted := str.tostring(math.round(seconds / 60 / 60)) + 'H'
    
    formatted

// FIXED: Calculate remaining time with validation
calculateRemainingTimeOriginal() =>
    result = 'n/a'
    
    if barstate.isrealtime and not na(higherTF) and higherTF != ""
        closeTime = time_close(higherTF)
        
        if not na(closeTime) and closeTime > timenow
            timeRemaining = (closeTime - timenow) / 1000
            
            if timeRemaining > 0
                days = math.floor(timeRemaining / 86400)
                hours = math.floor((timeRemaining - days * 86400) / 3600)
                minutes = math.floor((timeRemaining - days * 86400 - hours * 3600) / 60)
                seconds = math.floor(timeRemaining - days * 86400 - hours * 3600 - minutes * 60)

                // Validate ranges
                days := math.max(0, days)
                hours := math.max(0, math.min(23, hours))
                minutes := math.max(0, math.min(59, minutes))
                seconds := math.max(0, math.min(59, seconds))

                result := str.tostring(seconds, '00')
                
                if minutes > 0 or hours > 0 or days > 0
                    result := str.tostring(minutes, '00') + ':' + result
                
                if hours > 0 or days > 0
                    result := str.tostring(hours, '00') + ':' + result
                
                if days > 0
                    result := str.tostring(days) + 'D ' + result
    
    result

// FIXED: Format dashboard date with bounds checking
formatDashboardDate(timestamp) =>
    months = array.from("Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec")
    
    // Use chart timezone for local display
    dayVal = dayofmonth(timestamp)
    monthVal = month(timestamp)
    yearVal = year(timestamp)
    
    // FIXED: Add bounds checking for month array access
    monthStr = "Invalid"
    if monthVal >= 1 and monthVal <= 12 and array.size(months) >= 12
        monthStr := array.get(months, monthVal - 1)
    
    dayStr = dayVal < 10 ? "0" + str.tostring(dayVal) : str.tostring(dayVal)
    
    dayStr + "-" + monthStr + "-" + str.tostring(yearVal)

// FIXED: Format dashboard time with validation
formatDashboardTime(timestamp) =>
    // Get current time in chart timezone
    hourVal = hour(timestamp)
    minuteVal = minute(timestamp)
    
    // Validate ranges
    hourVal := math.max(0, math.min(23, hourVal))
    minuteVal := math.max(0, math.min(59, minuteVal))
    
    hourStr = hourVal < 10 ? "0" + str.tostring(hourVal) : str.tostring(hourVal)
    minuteStr = minuteVal < 10 ? "0" + str.tostring(minuteVal) : str.tostring(minuteVal)
    
    hourStr + ":" + minuteStr

